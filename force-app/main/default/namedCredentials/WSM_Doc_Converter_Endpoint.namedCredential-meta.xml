<?xml version="1.0" encoding="UTF-8"?>
<!--
    NOTE: Named Credentials cannot be deployed via Metadata API.
    This file is included as a reference for manual setup.
    Create in: Setup > Named Credentials > New

    Purpose: Used by buildRequest() as the callout endpoint for the external
    conversion service. Salesforce auto-attaches the SF Bearer token when
    HttpCalloutService calls callout:WSM_Doc_Converter_Endpoint/convert-sf.

    Post-setup: Add custom header X-API-Key with the conversion service API key
    in Setup > Named Credentials > WSM Doc Converter Endpoint > Custom Headers.
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>WSM Doc Converter Endpoint</label>
    <endpoint>https://YOUR_CONVERSION_SERVICE_URL</endpoint>
    <externalCredential>WSM_Doc_Converter</externalCredential>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>true</allowMergeFieldsInHeader>
    <calloutStatus>Enabled</calloutStatus>
</NamedCredential>
