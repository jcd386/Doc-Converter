<?xml version="1.0" encoding="UTF-8"?>
<!--
    NOTE: External Credentials cannot be deployed via Metadata API.
    This file is included as a reference for manual setup.
    Create in: Setup > Named Credentials > External Credentials > New
-->
<ExternalCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>WSM Doc Converter</label>
    <authenticationProtocol>OAuth</authenticationProtocol>
    <externalCredentialParameters>
        <parameterName>AuthProviderUrl</parameterName>
        <parameterType>AuthProviderUrl</parameterType>
        <parameterValue>https://YOUR_ORG_DOMAIN.my.salesforce.com/services/oauth2/token</parameterValue>
    </externalCredentialParameters>
    <externalCredentialParameters>
        <parameterName>GrantType</parameterName>
        <parameterType>AuthParameter</parameterType>
        <parameterValue>client_credentials</parameterValue>
    </externalCredentialParameters>
    <principals>
        <principalName>WSM_Doc_Converter_Principal</principalName>
        <principalType>NamedPrincipal</principalType>
        <sequenceNumber>1</sequenceNumber>
    </principals>
</ExternalCredential>
